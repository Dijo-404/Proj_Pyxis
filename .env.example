PYXIS_ENVIRONMENT=development
PYXIS_API_HOST=127.0.0.1
PYXIS_API_PORT=8000
PYXIS_DATABASE_PATH=./pyxis.db
PYXIS_DATABASE_AUTO_CREATE=true
PYXIS_LOG_LEVEL=INFO
PYXIS_GEMMA_PROVIDER=ollama
PYXIS_GEMMA_MODEL_PATH=./models/gemma
PYXIS_GEMMA_BASE_URL=http://127.0.0.1:11434/v1
PYXIS_GEMMA_MODEL=gemma3:4b
PYXIS_GEMMA_TIMEOUT_SECONDS=60
PYXIS_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
PYXIS_REVIEWER_ID=OFFICER-12
PYXIS_REVIEWER_NAME=Priyan Kannaa
PYXIS_REVIEWER_EMAIL=prie@gmail.com
PYXIS_REVIEWER_ROLE=Compliance Officer
PYXIS_DOCUMENT_STORAGE_PATH=./data/documents
PYXIS_REPORT_OUTPUT_PATH=./reports
PYXIS_MAX_DOCUMENT_BYTES=20971520
# Set to true only if you intend to use the cloud Gemini provider below; the local
# Ollama-backed runtime works regardless of this flag and never leaves the device.
PYXIS_ALLOW_EXTERNAL_AI=false
# Cloud Gemma (Investigation Orchestrator / Scenario Generator) via the Gemini API.
# Requires PYXIS_GEMMA_PROVIDER=gemini, PYXIS_ALLOW_EXTERNAL_AI=true, and a real key below.
PYXIS_GEMINI_API_KEY=
PYXIS_GEMINI_MODEL=gemma-3-27b-it
